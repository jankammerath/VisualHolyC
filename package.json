{
  "name": "visual-holyc",
  "displayName": "VisualHolyC — TempleOS in VS Code",
  "description": "Boot aiwnios.wasm (TempleOS compiled to WebAssembly) inside a VS Code webview.",
  "version": "0.1.0",
  "publisher": "visualholyc",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "templeos",
    "wasm",
    "webassembly",
    "aiwnios",
    "holyc"
  ],
  "main": "./extension.js",
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@vscode/vsce": "^2.32.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "visualHolyC.open",
        "title": "TempleOS: Boot",
        "category": "VisualHolyC"
      },
      {
        "command": "visualHolyC.restart",
        "title": "TempleOS: Restart",
        "category": "VisualHolyC"
      }
    ],
    "languages": [
      {
        "id": "holyc",
        "aliases": ["HolyC", "holyc"],
        "extensions": [".hc", ".HC", ".hc.z", ".HC.Z"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "holyc",
        "scopeName": "source.hc",
        "path": "./syntaxes/holyc.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "holyc-icons",
        "label": "HolyC File Icons",
        "path": "./fileicons/holyc-icon-theme.json"
      }
    ]
  }
}
